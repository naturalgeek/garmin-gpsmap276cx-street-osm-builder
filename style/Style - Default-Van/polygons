x_fuelmark=fuel {name '${name}'} [0x1070e resolution 23-23]
x_fuelmark=charging {name '${name}'} [0x16 resolution 23-23]
# -------------------------------------------------------------------
# This is the default mkgmap style file for converting closed OSM ways
# into Garmin polygons.
# Any line prefaced with # is a comment and will not be applied.
# Each line is a rule, of the generalised format:
#  OSM_tag(s)_to_match  [Garmin_type_code resolution]
# See http://wiki.openstreetmap.org/wiki/Mkgmap/help/style_rules
# and http://wiki.openstreetmap.org/wiki/Mkgmap/help/Custom_styles
# for more information.

addr:housenumber=* {set mkgmap:execute_finalize_rules=true}

leisure=* & sport=* & name=* {set name='${name} (${sport})'}
leisure=* & sport=* & name!=* {add name='${sport}'}

include 'inc/name';

# Whole-airport surface as one dedicated gray zone (0x0e = firmware light-gray,
# same tone as runways/aprons) so airports read as a distinct paved area.
aeroway=airport [0x0e resolution 20]
aeroway=aerodrome [0x0e resolution 20]
aeroway=runway & area=yes {name '${ref}'} [0x0e resolution 20]
(aeroway=taxiway | aeroway=taxilane) & area=yes {name '${ref}'} [0x0e resolution 24]
aeroway=heliport [0x07 resolution 20]
aeroway=helipad [0x0e resolution 22]

amenity=kindergarten [0x0a resolution 24]
amenity=cafe | amenity=fast_food | amenity=restaurant [0x08 resolution 22]
amenity=food_court [0x08 resolution 22]
amenity=college [0x0a resolution 24]
parking=underground | parking=multi-storey [0x06 resolution 22]
amenity=parking | parking=surface [0x05 resolution 22]
# fuel-as-lot removed; fuel/EV shown at 120m via preprocessed x_fuelmark squares (see below)
amenity=prison [0x04 resolution 22]
amenity=school [0x0a resolution 24]
# amenity=supermarket is superceded by shop=supermarket or landuse=retail
amenity=supermarket [0x08 resolution 22]
amenity=university [0x0a resolution 24]

healthcare=hospital | amenity=hospital | amenity=clinic [0x0b resolution 22]
# healthcare=* | amenity=dentist | amenity=doctors | amenity=nursing_home [0x0b resolution 23]   # CN does not draw dentist offices as hospital grounds

# Vegetation / green space: unified to one flat pale green (0x14) to match
# Garmin CN's single-green look. Firmware renders 0x14/0x15/0x1b/0x1c
# identically; forest tree-dot texture (0x50) intentionally dropped.
leisure=common [0x14 resolution 24]
leisure=garden [0x14 resolution 24]
leisure=golf_course [0x14 resolution 24]
leisure=ice_rink [0x19 resolution 24]
leisure=nature_reserve [0x14 resolution 19]
leisure=park [0x14 resolution 20]
leisure=pitch [0x14 resolution 24]
leisure=playground [0x14 resolution 24]
leisure=recreation_ground [0x14 resolution 24]
leisure=sports_center | leisure=sports_centre [0x14 resolution 24]
leisure=stadium [0x14 resolution 24]
leisure=track & area=yes [0x14 resolution 24]
leisure=water_park [0x09 resolution 24]

place=village [0x03 resolution 19]
place=suburb [0x02 resolution 19]

shop=* {add name='${shop|subst:"_=> "}'} [0x08 resolution 22]

# squares and plazas
place=square [0x25 resolution 22]
highway=pedestrian & (area=yes | mkgmap:mp_created=true) [0x25 resolution 22]
# following rule also renders a closed way without area attribute as a plaza
highway=pedestrian & area!=no [0x25 resolution 22]

# footways areas are similar, but should be explicity marked as such
highway=footway & area=yes [0x25 resolution 24]

highway=services [0x12 resolution 22]  # service station complex; show as retail
highway=rest_area & area!=no [0x05 resolution 22]  # show as parking lot

historic=* & historic!=no & historic!=yes & boundary!=* {add name='${historic|subst:"_=> "}'} [0x22 resolution 21]

landuse=basin [0x3f resolution 20]
landuse=reservoir | (natural=water & water=reservoir) [0x3f resolution 20]

dock=drydock [0x4c resolution 22]  # might also have natural=water

natural=bay [0x3d resolution 18]
natural=glacier [0x4d resolution 18]
# marsh/mud/wetland -> undrawn (yellow background like NT; 0x51 rendered a
# blue-dot marsh texture NT never shows).
natural=tundra [0x52 resolution 18]
natural=beach | natural=sand [0x53 resolution 20]
natural=water & water=canal [0x48 resolution 22]
natural=water & water=lock [0x4c resolution 22 default_name 'Lock']
natural=water & area_size() < 100000 [0x41 resolution 22]  # Small Lake
natural=water [0x3c resolution 18]
natural=waterfall | waterway=waterfall [0x47 resolution 21]
natural=sea {add mkgmap:skipSizeFilter=true; set mkgmap:drawLevel=2} [0x32 resolution 10]

waterway=riverbank [0x46 resolution 20]

# mop up any remaining water areas
waterway=* & waterway!=no & area!=no {add name='${waterway|subst:"_=> "}'} [0x3b resolution 22]

# allotments (Kleingärten) = managed gardens -> flat pale green like NT
# (was 0x4e = green tree-dot texture, which read as saturated forest).
landuse=allotments [0x14 resolution 21]
# cemetery: muted pale green (0x14) rather than the saturated woods-green 0x1a
landuse=cemetery | landuse=cemetary | amenity=grave_yard [0x14 resolution 21]
landuse=commercial [0x0f resolution 19]
landuse=construction [0x0c resolution 21]
landuse=farm [0x26 resolution 22]
# NT/City Navigator does NOT draw forest/farmland/wild land: those areas show
# the firmware's pale-yellow land background. So we leave them undrawn (yellow)
# and reserve the flat pale green (0x14) only for small MANAGED parks/grass,
# matching NT. (Forest as green 0x50/tree-dots is what made our map too green.)
# landuse=farmland  -> undrawn (yellow background, like NT)
landuse=farmyard [0x26 resolution 22]
# landuse=forest | landuse=wood  -> undrawn (yellow background, like NT)
# landuse=greenfield             -> undrawn (yellow background, like NT)
# landuse=meadow                 -> undrawn (yellow background, like NT)
landuse=grass [0x14 resolution 19]
landuse=military [0x04 resolution 19]
landuse=quarry [0x0c resolution 19]
landuse=recreation_ground [0x14 resolution 19]
# dedicate resolution 24 for building=* instead of related landuse=*
# Buildings render with the firmware drop-shadow (0x10900 = internal 0x89,
# render-class 0x6f). At 120m only LARGE buildings are drawn so the fixed-
# offset shadow stays attached (clean relief like CN); ALL buildings get the
# shadow at 80m and closer. Threshold in garmin-units^2 via area_size().
# CN-matching buildings: 0x08 = darker-yellow fill (body), then 0x10900 =
# firmware drop-shadow (relief edge). Layered via continue -> body + relief,
# exactly like Garmin NT. Both at res 22 (levels 0+1) so shadow shows at 120m
# too (needs the finer level-1 res 23 set in options). Probe-confirmed 2026-07-08.
building=* & building!=no {set mkgmap:skipSizeFilter=true} [0x10900 resolution 23 continue]
building=* & building!=no {set mkgmap:skipSizeFilter=true} [0x08 resolution 23]
landuse=industrial [0x0c resolution 19-23]
landuse=residential [0x10 resolution 19-23]
landuse=retail [0x12 resolution 20-23]
landuse=village_green [0x14 resolution 20]
# vineyard/orchard = agricultural -> undrawn (yellow background, like NT).
# landuse=vineyard  -> undrawn
# landuse=orchard   -> undrawn

military=airfield [0x04 resolution 20]
military=barracks [0x04 resolution 23]
military=danger_area [0x11 resolution 20]
military=range [0x04 resolution 20]

# natural=scrub / wood / heath / grassland / fell / meadow -> undrawn (yellow
# background, like NT). Only managed parks/grass get the pale green above.

# building tag should be last
amenity=* & area!=no & amenity!=grave_yard {add name='${amenity|subst:"_=> "}'} [0x23 resolution 24]
# CN-like buildings: light-gray fill (firmware style of 0x1070f) at 120m+80m,
# plus 0x13 outline at 80m. Probe-verified palette 2026-07-08.
tourism=* & area!=no & waterway!=* {add name='${tourism|subst:"_=> "}'} [0x21 resolution 24]

# man_made can be used on areas or lines
man_made=* & area!=no {add name='${man_made|subst:"_=> "}'} [0x24 resolution 24]

# render small named islands
place=island & name=* & area_size() < 1000000 [0x53 resolution 19]
place=islet & name=* [0x53 resolution 20]

<finalize>
# The finalizer section is executed for each element when a rule with an element type matches

# we need address info from buildings for the address search
include 'inc/address';

name=* {name '${name}'}
